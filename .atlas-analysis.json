  "keyFeatures": [
    "Full-featured ORM with associations (Has One, Has Many, Belongs To, Many To Many, Polymorphism)",
    "Lifecycle hooks (Before/After Create/Save/Update/Delete/Find)",
    "Eager loading via Preload and Joins",
    "Transactions, nested transactions, savepoints, and rollback to savepoints",
    "Context support, prepared statement mode, and dry-run mode",
    "Batch insert, FindInBatches, and Find to Map",
    "SQL Builder with Upsert, Locking, Optimizer hints, and NamedArg",
    "Auto migrations for schema management",
    "Structured logging with configurable log levels",
    "Extensible plugin API (Database Resolver, Prometheus, etc.)",
    "Soft delete via DeletedAt field",
    "Generics-based type-safe query API (G[T])"
  ],
  "publicApiSurface": [
    "gorm.Open(dialector Dialector, opts ...Option) (*DB, error)",
    "(*DB).Create(value interface{}) *DB",
    "(*DB).Save(value interface{}) *DB",
    "(*DB).First(dest interface{}, conds ...interface{}) *DB",
    "(*DB).Find(dest interface{}, conds ...interface{}) *DB",
    "(*DB).Update(column string, value interface{}) *DB",
    "(*DB).Updates(values interface{}) *DB",
    "(*DB).Delete(value interface{}, conds ...interface{}) *DB",
    "(*DB).Where(query interface{}, args ...interface{}) *DB",
    "(*DB).Preload(query string, args ...interface{}) *DB",
    "(*DB).Joins(query string, args ...interface{}) *DB",
    "(*DB).Transaction(fc func(tx *DB) error, opts ...*sql.TxOptions) error",
    "(*DB).AutoMigrate(dst ...interface{}) error",
    "(*DB).Association(column string) *Association",
    "(*DB).Session(config *Session) *DB",
    "(*DB).Scopes(funcs ...func(*DB) *DB) *DB",
    "(*DB).Use(plugin Plugin) error",
    "(*DB).Callback() *callbacks",
    "(*DB).ToSQL(queryFn func(tx *DB) *DB) string",
    "gorm.G[T](db *DB, opts ...clause.Expression) Interface[T]",
    "gorm.Model (embedded struct with ID, CreatedAt, UpdatedAt, DeletedAt)",
    "gorm.Config (configuration struct)",
    "gorm.Dialector (interface for database drivers)",
    "gorm.Plugin (interface for plugins)"
  ]
}
